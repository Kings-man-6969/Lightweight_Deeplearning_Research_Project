   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-6",
   "metadata": {},
   "source": ["## 6. Inference Speed Benchmark"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "benchmark",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Measure average inference time per image\n",
    "dummy_input = torch.randn(1, 3, IMG_SIZE, IMG_SIZE).to(device)\n",
    "model.eval()\n",
    "\n",
    "runs = 50\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(runs):\n",
    "        _ = model(dummy_input)\n",
    "elapsed = (time.time() - start) / runs * 1000\n",
    "print(f'EfficientNet-B4 avg inference time: {elapsed:.2f} ms/image')"
   ]
  },
  {
